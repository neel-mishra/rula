# ─────────────────────────────────────────────────────────────────────────────
# AI Inbox Chief of Staff — Environment Template
# Copy to .env.dev, .env.staging, .env.prod and fill real values.
# Never commit files with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev                          # dev | staging | prod
APP_SECRET_KEY=CHANGE_ME_32_BYTES    # used for JWT signing; generate: openssl rand -hex 32
LOG_LEVEL=INFO

# CORS (split-host: Next.js on Vercel + API on Render). Comma-separated origins.
# Dev always allows http://localhost:3000.
CORS_ALLOWED_ORIGINS=
# If true, also allow https://*.vercel.app (preview deployments).
CORS_ALLOW_VERCEL_PREVIEW=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://inbox_user:inbox_pass@localhost:5432/inbox_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend Selection (MVP vs connector-rich) ────────────────────────────────
INGEST_SOURCE=gmail                 # gmail | fixture | imap
QUEUE_BACKEND=redis_streams         # redis_streams | sqs | inline
MAILBOX_BACKEND=gmail               # gmail | local

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# SQS queue URLs (created by Terraform)
SQS_INGEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-ingest
SQS_TRIAGE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-triage
SQS_DRAFT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-draft
SQS_BRIEF_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-brief
SQS_MEMORY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-memory
SQS_EVAL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-eval
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/123456789012/inbox-dlq

# S3 (optional)
S3_AUDIT_BUCKET=inbox-audit-exports-dev
S3_EVAL_BUCKET=inbox-eval-artifacts-dev

# ── Encryption ────────────────────────────────────────────────────────────────
# KMS key ARN for envelope encryption of OAuth refresh tokens
KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/CHANGE_ME
# Fallback symmetric key (base64-encoded 32-byte key) for local/dev only
TOKEN_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# ── Google / Gmail OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:8000/mailbox-connect/gmail/callback
# Scopes: readonly + labels + drafts (no send)
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.labels,https://www.googleapis.com/auth/gmail.modify,https://www.googleapis.com/auth/gmail.compose
# Gmail push notification topic (Pub/Sub or direct webhook path)
GMAIL_WEBHOOK_TOPIC=projects/CHANGE_ME_PROJECT/topics/inbox-gmail-push
GMAIL_WEBHOOK_SECRET=CHANGE_ME

# ── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME        # fallback provider

# Primary model routing
LLM_PRIMARY_PROVIDER=anthropic
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o-mini

# Token budget per mailbox per day (USD cents)
LLM_DAILY_BUDGET_CENTS_PER_MAILBOX=75
LLM_MONTHLY_BUDGET_CENTS=10000
LLM_BUDGET_DEGRADATION_THRESHOLD=0.80  # degrade at 80% of budget

# ── Observability ─────────────────────────────────────────────────────────────
# OTLP HTTP endpoint (collector listens on :4318 for HTTP, :4317 for gRPC).
# Leave empty to disable tracing (init_tracing becomes a no-op).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=inbox-chief-of-staff
OTEL_ENVIRONMENT=dev

# Optional: Datadog / Honeycomb
# DD_API_KEY=CHANGE_ME
# HONEYCOMB_API_KEY=CHANGE_ME

# ── Audit Export ─────────────────────────────────────────────────────────────
# Daily NDJSON export of audit_events to S3. Empty bucket = worker no-op.
AUDIT_EXPORT_S3_BUCKET=
AUDIT_EXPORT_S3_PREFIX=audit/

# ── Brief Scheduler ───────────────────────────────────────────────────────────
BRIEF_MORNING_HOUR=8    # UTC hour for morning brief
BRIEF_AFTERNOON_HOUR=17 # UTC hour for afternoon brief
BRIEF_TIMEZONE=America/New_York

# ── Security Controls ─────────────────────────────────────────────────────────
# Confidence thresholds for autonomous mailbox mutations
TRIAGE_HIGH_CONFIDENCE_THRESHOLD=0.90
TRIAGE_MEDIUM_CONFIDENCE_THRESHOLD=0.70
# Below medium_confidence: no mutation, route to manual review queue

# Max undo window for system-initiated mutations (seconds)
MUTATION_UNDO_WINDOW_SECONDS=604800  # 7 days

# Kill switch: set to "true" to halt all LLM calls and revert to deterministic-only mode
KILL_SWITCH_LLM=false
# Kill switch: set to "true" to halt all autonomous mailbox mutations
KILL_SWITCH_MUTATIONS=false

# Shadow mode: full pipeline runs but no mutations or Gmail drafts created
SHADOW_MODE=false

# ── SES (Brief Delivery) ────────────────────────────────────────────────────
SES_FROM_ADDRESS=briefs@yourdomain.com
SES_REGION=us-east-1
SES_ENABLED=false  # Enable after SES domain verification + DKIM

# ── Model Routing ────────────────────────────────────────────────────────────
# Cheaper model for low-stakes tasks (brief summaries, category tagging)
LLM_CHEAP_PROVIDER=anthropic
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001

# ── Progressive Rollout ──────────────────────────────────────────────────────
# Default activation mode for new mailboxes: shadow | observe | auto
DEFAULT_ACTIVATION_MODE=shadow
