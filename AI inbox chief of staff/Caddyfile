{
	email {$CADDY_ADMIN_EMAIL}
}

{$APP_DOMAIN} {
	encode gzip

	@apiWithPrefix path /api/*
	handle_path @apiWithPrefix {
		reverse_proxy api:8000
	}

	@apiDirect path /health/* /webhooks/* /mailbox-connect/* /auth/* /mailboxes/* /assistant/* /undo/* /feedback/* /data/* /activity/* /briefs/* /memories/* /experiments/* /slo/* /admin/*
	handle @apiDirect {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
