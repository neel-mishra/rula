# AI Inbox Chief of Staff — Minimal MVP Environment

APP_ENV=dev
APP_SECRET_KEY=CHANGE_ME_32_BYTES
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://inbox_user:inbox_pass@localhost:5432/inbox_dev
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

REDIS_URL=redis://localhost:6379/0

INGEST_SOURCE=gmail
QUEUE_BACKEND=redis_streams
