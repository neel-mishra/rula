# ─────────────────────────────────────────────────────────────────────────────
# AI Inbox Chief of Staff — STAGING Environment Template
#
# THIS IS A TEMPLATE. Copy to .env.staging and fill via your secrets manager
# (AWS Secrets Manager, SOPS, Doppler, etc.). NEVER commit a copy that
# contains real values.
#
# Required in staging (validate_for_environment will fail if any are unset
# or still hold a CHANGE_ME placeholder):
#   APP_SECRET_KEY, DATABASE_URL, KMS_KEY_ARN, TOKEN_ENCRYPTION_KEY,
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GMAIL_WEBHOOK_SECRET,
#   ANTHROPIC_API_KEY, OPENAI_API_KEY, AWS_ACCOUNT_ID
#
# Conditional requirement:
#   If QUEUE_BACKEND=sqs, SQS_INGEST_QUEUE_URL and SQS_DLQ_URL are required.
#
# Optional in staging (have safe defaults or are feature-gated):
#   SES_*  (briefs may not be delivered to real users in staging)
#   SLACK_WEBHOOK_URL, PAGERDUTY_ROUTING_KEY (alerts can be log-only)
#   S3_*   (audit/eval can be skipped while iterating)
#   OTEL_* (defaults to localhost; staging may use the platform collector)
#   GOLD_* and KILL_SWITCH_* feature flags
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=staging
APP_SECRET_KEY=CHANGE_ME_32_BYTES        # openssl rand -hex 32
LOG_LEVEL=INFO

# CORS (split-host: Vercel or other SPA origins calling this API)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CORS_ALLOW_VERCEL_PREVIEW=true

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://inbox_user:CHANGE_ME@inbox-staging.cluster-XXXX.us-east-1.rds.amazonaws.com:5432/inbox_staging
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://inbox-staging.XXXX.cache.amazonaws.com:6379/0

# ── Backend Selection ─────────────────────────────────────────────────────────
INGEST_SOURCE=gmail
QUEUE_BACKEND=redis_streams
MAILBOX_BACKEND=gmail

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=CHANGE_ME

SQS_INGEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-ingest-staging
SQS_TRIAGE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-triage-staging
SQS_DRAFT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-draft-staging
SQS_BRIEF_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-brief-staging
SQS_MEMORY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-memory-staging
SQS_EVAL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-eval-staging
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-dlq-staging

# Optional in staging
S3_AUDIT_BUCKET=inbox-audit-exports-staging
S3_EVAL_BUCKET=inbox-eval-artifacts-staging

# ── Encryption (REQUIRED) ────────────────────────────────────────────────────
KMS_KEY_ARN=arn:aws:kms:us-east-1:CHANGE_ME:key/CHANGE_ME
TOKEN_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# ── Google / Gmail OAuth (REQUIRED) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://staging.inbox.example.com/mailbox-connect/gmail/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.labels,https://www.googleapis.com/auth/gmail.modify,https://www.googleapis.com/auth/gmail.compose
GMAIL_WEBHOOK_TOPIC=projects/CHANGE_ME_PROJECT/topics/inbox-gmail-push-staging
GMAIL_WEBHOOK_SECRET=CHANGE_ME

# ── LLM Providers (REQUIRED) ─────────────────────────────────────────────────
# Use lower-traffic / lower-budget keys in staging.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME

LLM_PRIMARY_PROVIDER=anthropic
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o-mini

# Lower budgets in staging to bound spend on synthetic / replay traffic.
LLM_DAILY_BUDGET_CENTS_PER_MAILBOX=25
LLM_MONTHLY_BUDGET_CENTS=2500
LLM_BUDGET_DEGRADATION_THRESHOLD=0.80

LLM_CHEAP_PROVIDER=anthropic
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001

# ── Observability (optional) ─────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.staging.svc.cluster.local:4317
OTEL_SERVICE_NAME=inbox-chief-of-staff
OTEL_ENVIRONMENT=staging

# ── Brief Scheduler ───────────────────────────────────────────────────────────
BRIEF_MORNING_HOUR=8
BRIEF_AFTERNOON_HOUR=17
BRIEF_TIMEZONE=America/New_York

# ── Security Controls ─────────────────────────────────────────────────────────
TRIAGE_HIGH_CONFIDENCE_THRESHOLD=0.90
TRIAGE_MEDIUM_CONFIDENCE_THRESHOLD=0.70
MUTATION_UNDO_WINDOW_SECONDS=604800

KILL_SWITCH_LLM=false
KILL_SWITCH_MUTATIONS=false

# Default to shadow mode in staging until eval gates pass.
SHADOW_MODE=true
DEFAULT_ACTIVATION_MODE=shadow

# ── SES (optional in staging) ────────────────────────────────────────────────
SES_FROM_ADDRESS=briefs-staging@example.com
SES_REGION=us-east-1
SES_ENABLED=false
