# ─────────────────────────────────────────────────────────────────────────────
# AI Inbox Chief of Staff — PRODUCTION Environment Template
#
# THIS IS A TEMPLATE. Copy to .env.prod and populate exclusively from your
# secrets manager (AWS Secrets Manager + IAM-bound role recommended).
# NEVER commit a copy that contains real values. NEVER store this file
# alongside production secrets — load them at boot.
#
# Required in prod (validate_for_environment will fail at boot if any are
# unset or still hold a CHANGE_ME placeholder):
#   APP_SECRET_KEY, DATABASE_URL, KMS_KEY_ARN, TOKEN_ENCRYPTION_KEY,
#   GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GMAIL_WEBHOOK_SECRET,
#   ANTHROPIC_API_KEY, OPENAI_API_KEY, AWS_ACCOUNT_ID,
#   SES_FROM_ADDRESS, S3_AUDIT_BUCKET
#
# Conditional requirement:
#   If QUEUE_BACKEND=sqs, SQS_INGEST_QUEUE_URL, SQS_TRIAGE_QUEUE_URL,
#   SQS_DRAFT_QUEUE_URL, SQS_BRIEF_QUEUE_URL, and SQS_DLQ_URL are required.
#
# Optional in prod (have safe defaults or are feature-gated):
#   SLACK_WEBHOOK_URL, PAGERDUTY_ROUTING_KEY  (incident routing)
#   OTEL_*                                    (observability collector)
#   GOLD_*  KILL_SWITCH_*  SHADOW_MODE        (feature flags / safety)
#   DD_API_KEY, HONEYCOMB_API_KEY             (vendor metrics)
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=prod
APP_SECRET_KEY=CHANGE_ME_32_BYTES        # openssl rand -hex 32
LOG_LEVEL=INFO
APP_DOMAIN=inbox.example.com
CADDY_ADMIN_EMAIL=ops@example.com

# CORS (split-host: list production SPA origins; avoid preview regex in strict prod)
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
CORS_ALLOW_VERCEL_PREVIEW=false

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://inbox_user:CHANGE_ME@inbox-prod.cluster-XXXX.us-east-1.rds.amazonaws.com:5432/inbox_prod
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
POSTGRES_DB=inbox_prod
POSTGRES_USER=inbox_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=rediss://inbox-prod.XXXX.cache.amazonaws.com:6379/0
REDIS_PASSWORD=CHANGE_ME

# ── Backend Selection ─────────────────────────────────────────────────────────
INGEST_SOURCE=gmail
MAILBOX_BACKEND=gmail

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=CHANGE_ME
AWS_ENDPOINT_URL=

SQS_INGEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-ingest-prod
SQS_TRIAGE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-triage-prod
SQS_DRAFT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-draft-prod
SQS_BRIEF_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-brief-prod
SQS_MEMORY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-memory-prod
SQS_EVAL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-eval-prod
SQS_DLQ_URL=https://sqs.us-east-1.amazonaws.com/CHANGE_ME/inbox-dlq-prod

S3_AUDIT_BUCKET=inbox-audit-exports-prod
S3_EVAL_BUCKET=inbox-eval-artifacts-prod
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# ── Encryption (REQUIRED) ────────────────────────────────────────────────────
# Production must use a real KMS CMK; the symmetric fallback is only for dev.
KMS_KEY_ARN=arn:aws:kms:us-east-1:CHANGE_ME:key/CHANGE_ME
TOKEN_ENCRYPTION_KEY=CHANGE_ME_BASE64_32_BYTES

# ── Google / Gmail OAuth (REQUIRED) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=https://inbox.example.com/mailbox-connect/gmail/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.labels,https://www.googleapis.com/auth/gmail.modify,https://www.googleapis.com/auth/gmail.compose
GMAIL_WEBHOOK_TOPIC=projects/CHANGE_ME_PROJECT/topics/inbox-gmail-push-prod
GMAIL_WEBHOOK_SECRET=CHANGE_ME

# ── LLM Providers (REQUIRED) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME

LLM_PRIMARY_PROVIDER=anthropic
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o-mini

LLM_DAILY_BUDGET_CENTS_PER_MAILBOX=75
LLM_MONTHLY_BUDGET_CENTS=10000
LLM_BUDGET_DEGRADATION_THRESHOLD=0.80

LLM_CHEAP_PROVIDER=anthropic
LLM_CHEAP_MODEL=claude-haiku-4-5-20251001

# ── Observability (optional, but strongly recommended) ──────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.example.com:4317
OTEL_SERVICE_NAME=inbox-chief-of-staff
OTEL_ENVIRONMENT=prod

# ── Incident routing (optional but recommended) ─────────────────────────────
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=

# ── Brief Scheduler ───────────────────────────────────────────────────────────
BRIEF_MORNING_HOUR=8
BRIEF_AFTERNOON_HOUR=17
BRIEF_TIMEZONE=America/New_York

# ── Security Controls ─────────────────────────────────────────────────────────
TRIAGE_HIGH_CONFIDENCE_THRESHOLD=0.90
TRIAGE_MEDIUM_CONFIDENCE_THRESHOLD=0.70
MUTATION_UNDO_WINDOW_SECONDS=604800

# Kill switches default off; flip via runtime store, not env, for incidents.
KILL_SWITCH_LLM=false
KILL_SWITCH_MUTATIONS=false

# Shadow mode and progressive rollout — production ramps from shadow → auto.
SHADOW_MODE=false
DEFAULT_ACTIVATION_MODE=shadow
QUEUE_BACKEND=redis_streams

# ── SES (REQUIRED — briefs are delivered in prod) ───────────────────────────
SES_FROM_ADDRESS=briefs@example.com
SES_REGION=us-east-1
SES_ENABLED=true
SES_INBOUND_SECRET=CHANGE_ME

# ── Gold-eval pipeline (optional, off until OAuth + connectors live) ────────
GOLD_SAMPLING_ENABLED=false
GOLD_EVAL_ENABLED=false
GOLD_SAMPLE_NAME_HASH_SALT=CHANGE_ME
