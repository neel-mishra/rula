# --- LLM Providers ---
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Gemini / Vertex (optional; use for Vertex-based auth in production) ---
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# --- Model Routing ---
MODEL_PRIMARY=claude
MODEL_FALLBACK=gemini
GENERATION_MODE=fast_mode

# --- App Environment ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Safety / Feature Flags ---
RULA_DISABLE_PROSPECTING=false
RULA_DISABLE_MAP=false

# --- Gap-plan: prospecting DQ / lineage / queue (all optional) ---
# YAML policy path; when unset, full pipeline runs (no DQ short-circuit).
# RULA_DQ_POLICY_PATH=/absolute/path/to/dq_policy.yaml
# Minimum discovery questions for generator + judge (default 3).
# RULA_MIN_DISCOVERY_QUESTIONS=3
# Include lineage_export block in JSON exports (set to 0 to omit).
# RULA_EXPORT_LINEAGE=1
# Bulk default: file_order | heuristic (UI can override per run).
# RULA_BULK_DEFAULT_QUEUE=file_order
