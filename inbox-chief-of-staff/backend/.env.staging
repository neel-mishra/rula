NODE_ENV=staging
# Set APP_BASE_URL to your Vercel production URL after vercel --prod completes
APP_BASE_URL=https://REPLACE_WITH_VERCEL_URL
# Set API_BASE_URL to your Cloud Run URL after gcloud run deploy completes
API_BASE_URL=https://REPLACE_WITH_CLOUD_RUN_URL
WEBHOOK_BASE_URL=https://REPLACE_WITH_CLOUD_RUN_URL

GOOGLE_CLIENT_ID=98310100927-kpuns8rdauinm5ufdbc3pb5659a98k4d.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=REPLACE_WITH_SECRET_FROM_SECRET_MANAGER
GOOGLE_OAUTH_REDIRECT_URI=https://REPLACE_WITH_CLOUD_RUN_URL/auth/callback
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.labels,https://www.googleapis.com/auth/gmail.compose
GMAIL_WATCH_LABELS=INBOX

LLM_PROVIDER=anthropic
LLM_API_KEY=REPLACE_WITH_SECRET_FROM_SECRET_MANAGER
LLM_MODEL_TRIAGE=claude-haiku-4-5-20251001
LLM_MODEL_DRAFT=claude-sonnet-4-6
LLM_MODEL_BRIEF=claude-haiku-4-5-20251001

# Cloud SQL connection string via Unix socket (Cloud Run)
# Format: postgresql+asyncpg://USER:PASSWORD@/DB_NAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_WITH_DB_PASSWORD@/inbox_chief?host=/cloudsql/inbox-chief-of-staff-494719:us-central1:inbox-chief-staging
DATABASE_POOL_SIZE=10
VECTOR_STORE_MODE=pgvector
PGVECTOR_EMBEDDING_DIM=1536

QUEUE_PROVIDER=cloud_tasks
QUEUE_URL=https://cloudtasks.googleapis.com/v2/projects/inbox-chief-of-staff-494719/locations/us-central1/queues/inbox-chief-staging

PUBSUB_TOPIC=projects/inbox-chief-of-staff-494719/topics/inbox-chief-of-staff

OBJECT_STORAGE_BUCKET=inbox-chief-staging-artifacts
OBJECT_STORAGE_REGION=us-central1

