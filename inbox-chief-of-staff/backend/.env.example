# =============================================================================
# Inbox Chief of Staff — Backend Environment Variables
# =============================================================================
# Copy this file to .env (local dev) or .env.production (Cloud Run deploy).
# Never commit a file containing real secrets.
#
# Run `scripts/provision_gcp.sh` to create GCP resources and get the values
# for the Pub/Sub, Cloud Tasks, Cloud SQL, and GCS sections below.
# =============================================================================


# =============================================================================
# App Config
# =============================================================================

# Environment: development | staging | production
NODE_ENV=development

# Public URL of the frontend app (used for CORS and OAuth redirects).
APP_BASE_URL=http://localhost:3000

# Public URL of this API server.
API_BASE_URL=http://localhost:8000

# Additional CORS origins beyond APP_BASE_URL, comma-separated.
# Example: https://staging.example.com,https://preview.example.com
EXTRA_CORS_ORIGINS=

# Publicly reachable base URL of this API, used to build the Pub/Sub push
# endpoint. In local dev, set this to your ngrok URL (run setup_ngrok_dev.sh).
# In production, set this to your Cloud Run service URL.
WEBHOOK_BASE_URL=https://your-ngrok-or-cloud-run-url.example.com

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Optional Sentry DSN for error tracking. Leave empty to disable.
ERROR_TRACKING_DSN=

# Version tag for eval/gold datasets.
EVAL_DATASET_VERSION=v1


# =============================================================================
# Google OAuth (https://console.cloud.google.com/apis/credentials)
# =============================================================================

# OAuth 2.0 client ID from the GCP Console (Web Application type).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Corresponding client secret.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Must match an Authorized Redirect URI registered in the OAuth client.
# Production: https://your-cloud-run-url/auth/callback
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/callback

# Space-or-comma-separated Gmail OAuth scopes. Defaults are read-only + labels + compose.
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.labels,https://www.googleapis.com/auth/gmail.compose

# Comma-separated Gmail label IDs to watch for push notifications.
GMAIL_WATCH_LABELS=INBOX


# =============================================================================
# Gmail Pub/Sub Push
# =============================================================================
# Created by provision_gcp.sh. Format: projects/{gcp_project}/topics/{topic}.
# Leave empty to skip watch registration (use /dev/ingest for manual testing).
PUBSUB_TOPIC=projects/inbox-chief-of-staff-494719/topics/inbox-chief-of-staff


# =============================================================================
# LLM
# =============================================================================

# LLM provider. Only "anthropic" is supported in Phase 1.
LLM_PROVIDER=anthropic

# Anthropic API key (https://console.anthropic.com/settings/keys).
LLM_API_KEY=sk-ant-your-anthropic-api-key

# Model used for email triage / classification.
LLM_MODEL_TRIAGE=claude-haiku-4-5-20251001

# Model used for draft generation.
LLM_MODEL_DRAFT=claude-sonnet-4-6

# Model used for daily brief generation.
LLM_MODEL_BRIEF=claude-haiku-4-5-20251001


# =============================================================================
# Database (Cloud SQL Postgres 15 + pgvector)
# =============================================================================

# Async SQLAlchemy URL.
# Local dev:    postgresql+asyncpg://postgres:postgres@localhost:5432/inbox_chief
# Cloud Run:    postgresql+asyncpg://postgres:DB_PASSWORD@/inbox_chief?host=/cloudsql/CONNECTION_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/inbox_chief

# Connection pool size per worker process.
DATABASE_POOL_SIZE=10

# Vector store backend. Only "pgvector" is supported in Phase 1.
VECTOR_STORE_MODE=pgvector

# Embedding dimension. Must match the model used for embeddings (1536 for text-embedding-3-small).
PGVECTOR_EMBEDDING_DIM=1536

# Cloud SQL instance connection name (PROJECT:REGION:INSTANCE).
# Used by the Cloud Run --add-cloudsql-instances flag in deploy_cloud_run.sh.
# Example: inbox-chief-of-staff-494719:us-central1:inbox-chief-of-staff-db
CLOUD_SQL_CONNECTION_NAME=inbox-chief-of-staff-494719:us-central1:inbox-chief-of-staff-db


# =============================================================================
# Cloud Tasks
# =============================================================================

# Queue provider. Only "cloud_tasks" is supported.
QUEUE_PROVIDER=cloud_tasks

# Full resource URL of the Cloud Tasks queue created by provision_gcp.sh.
# Format: https://cloudtasks.googleapis.com/v2/projects/{project}/locations/{region}/queues/{queue}
QUEUE_URL=https://cloudtasks.googleapis.com/v2/projects/inbox-chief-of-staff-494719/locations/us-central1/queues/inbox-chief-of-staff-tasks


# =============================================================================
# Object Storage (GCS)
# =============================================================================

# GCS bucket name created by provision_gcp.sh (no gs:// prefix).
OBJECT_STORAGE_BUCKET=inbox-chief-of-staff-artifacts-inbox-chief-of-staff-494719

# GCS bucket region. Must match the bucket's location.
OBJECT_STORAGE_REGION=us-central1


# =============================================================================
# Security
# =============================================================================

# Fernet key for encrypting OAuth refresh tokens at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY_ID=your-fernet-encryption-key-base64

# Secret used to sign session tokens. Must be a strong random string in production.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-in-production
